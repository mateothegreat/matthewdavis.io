---
import Breadcrumbs from "$components/breadcrumbs/breadcrumbs.svelte";
import { getCollection } from "astro:content";
import Blog from "../../layouts/blog.astro";
import Card from "./card.svelte";
import Featured from "./featured.svelte";

const posts = (await getCollection("blog")).sort((a, b) => new Date(a.data.publish).valueOf() - new Date(b.data.publish).valueOf());
const featured = posts.filter((post) => post.data.featured);
---

<Blog>
  <Breadcrumbs crumbs={[{ label: "Blog", href: "/blog" }]} />
  <div class="">
    {featured.map(async (post) => <Featured post={post} />)}
  </div>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
    {posts.map((post) => <Card post={post} />)}
  </div>
</Blog>
