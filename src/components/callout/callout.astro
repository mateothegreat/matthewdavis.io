---
import type { Variant } from "../variants.ts";
import CalloutComponent from "./callout-component.svelte";

interface Props {
  variant: Variant;
  message: string;
}

if (!Astro.props.variant) {
  throw new Error("variant and message are required");
}
---

<CalloutComponent variant={Astro.props.variant} message={Astro.props.message}>
  <slot />
</CalloutComponent>
